# =======================================================================
# 嵌入式端 (STM32 / Keil MDK / STM32CubeIDE)
# =======================================================================
# 忽略 Keil 编译生成的庞大中间文件和临时文件
**/OBJ/
**/List/
**/build/
*.o
*.d
*.crf
*.lnp
*.axf
*.htm
*.sct
*.dep
*.lst
*.map
*.iex
*.i
*.vopt
*.bak
*.__i
*.pbi
*.pbd

# 忽略 Keil 用户的本地个性化配置
*.uvgui.*
*.uv2.bak
*.uvoptx.bak
*.wdg

# 忽略 STM32CubeMX 自动生成的备份和生成日志
*.mxproject
~*

# =======================================================================
# HiSpark Studio / OpenHarmony / Eclipse 编译环境
# =======================================================================
# 忽略编译输出目录（通常会把所有的 .o, .bin, .elf 放在 out 或 output 文件夹下）
**/out/
**/output/
**/build_cache/
**/interim_binary/

# 忽略 GN 和 Ninja 编译工具链产生的临时缓存与描述文件
**.ninja
**.ninja_deps
**.ninja_log
**/.gn
**/args.gn

# 忽略 HiSpark Studio (Eclipse / VS Code 内核) 自带的项目配置文件
#（这些文件包含本地的绝对路径，传到 GitHub 会导致队友的 IDE 报路径错误）
**/.metadata/
**/.settings/
**/.project
**/.cproject
**/.pydevproject
**/.factorypath
*.hiproj

# 忽略编译过程中的日志文件
**/build.log
**/compile_commands.json

# 忽略编译分析产物
**/analyzerJson/

# 忽略本地用户特有的配置（如历史打开的文件、断点信息）
**/.vscode/
**/.idea/
*.userdata

# =======================================================================
# 预编译二进制库 (SDK 自带，用户从环境配置获取)
# =======================================================================
**/*.a
*.bin
*.elf
*.hex
*.so
*.chm
*.zip
*.img
*.patch
*.diff

# =======================================================================
# 开发工具 (作为环境配置的一部分，用户单独下载)
# =======================================================================
# =======================================================================
# 文档 (用户从环境配置或官网自行获取)
# =======================================================================
firmware/docs/
firmware/vendor/*/doc/
firmware/src/docs/uni_hb_m_solution/
firmware/src/docs/jx_firm/

# =======================================================================
# 开发工具 (作为环境配置的一部分，用户单独下载)
# =======================================================================
firmware/src/tools/

# =======================================================================
# 示例与演示代码 (厂商提供，用户从 SDK 单独获取)
# =======================================================================
firmware/src/application/samples/Farsight/
firmware/src/application/samples/peripheral/
firmware/vendor/*/peripheral/
firmware/vendor/*/products/
firmware/vendor/*/demo/
firmware/vendor/*/Farsight/
firmware/vendor/*/wifi/
firmware/vendor/developers/demo/

# =======================================================================
# Python 上位机 & AI 模型端 (Python / PyTorch)
# =======================================================================
# 忽略 Python 字节码缓存（这会导致组员代码冲突）
**/__pycache__/
*.py[cod]
*$py.class

.pytest_cache/
/.pytest_cache/

# 忽略 Python 类型检查与 linter 缓存
.mypy_cache/
.ruff_cache/
/.mypy_cache/
/.mypy_cache/

# 忽略 Python 虚拟环境
.venv/
venv/
env/
ENV/

# 忽略环境配置文件（包含敏感凭据）
.env
server/.env.dev
server/.env.prod

# 忽略 Jupyter Notebook 的缓存
.ipynb_checkpoints/

# 忽略打包生成的 build/dist 以及 egg-info（如果用 pyinstaller 打包上位机的话）
bin/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/


# =======================================================================
# 第三方库自带 VS 工程文件 (与 RISC-V 固件无关)
# =======================================================================
*.code-workspace
*.vcxproj*
*.sln
*.csr

# mbedtls / GmSSL 单元测试证书和密钥 (不跑测试不需要)
firmware/src/open_source/mbedtls/**/tests/data_files/
firmware/src/open_source/GmSSL3.0/certs/

# =======================================================================
# 操作系统、IDE 与其它
# =======================================================================
# 忽略操作系统的隐藏文件
.DS_Store
Thumbs.db

# 忽略主流编辑器的本地配置
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

*.log

reference/

.claude/
.opencode/
CLAUDE.md

# =======================================================================
# 鸿蒙移动应用 (HarmonyOS / DevEco Studio)
# =======================================================================
# 忽略 Node.js 和 ohpm 依赖包目录
**/node_modules/
**/oh_modules/

# 忽略本地 SDK 路径及个性化配置
**/local.properties
**/.hvigor/
**/.cxx/
**/.clangd/
**/.clang-format
**/.clang-tidy
**/.appanalyzer/
**/oh-package-lock.json5
