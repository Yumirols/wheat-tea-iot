config ENABLE_HELLOWORLD
    bool
    prompt "01-Enable the Test of ENABLE_HELLOWORLD."
    default n
    depends on FARMEYE_GUARD_SAMPLE
    help
        This option means enable the test of helloworld.

if ENABLE_HELLOWORLD
menu "Config HelloWorld"
osource "application/samples/farmeye_guard/01-hello/Kconfig"
endmenu
endif

